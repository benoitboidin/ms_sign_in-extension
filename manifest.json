{
  "manifest_version": 3,
  "name": "MS Sign-in AutoClick",
  "version": "0.1.0",
  "description": "Automatically clicks the Sign in button on teams.cloud.microsoft to dismiss repeated sign-in prompts.",
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://teams.cloud.microsoft/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://teams.cloud.microsoft/*"
  ]
}